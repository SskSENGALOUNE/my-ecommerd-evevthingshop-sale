// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum ColorType {
  RED
  GREEN
  BLUE
  YELLOW
  BLACK
  WHITE
  GRAY
  PURPLE
  ORANGE
  PINK
  BROWN
  GOLD
  SILVER
}

enum Status {
  PENDING
  COMPLETED
  FAILED
}

enum BankType {
  BCEL
  JDB
  LDB
}

enum ShippingType {
  RAIDER
  ANOUSITH_EXPRESS
  HOUNGALOUN_EXPRESS
  MIXAY_EXPRESS
  UNITEL_EXPRESS
}

enum PaymentMethod {
  QR // โอนผ่าน QR + แนบสลิป
  COD // เก็บเงินปลายทาง
}

enum OrderStatus {
  PENDING // รอชำระเงิน
  CONFIRMED // ยืนยันชำระเงินแล้ว
  PROCESSING // กำลังเตรียมของ
  SHIPPED // ส่งแล้ว
  DELIVERED // ลูกค้าได้รับ
  CANCELLED // ยกเลิก
  REFUNDED // คืนเงิน
}

enum ShipmentStatus {
  PREPARING
  SHIPPED
  DELIVERED
}

// ============================================
// AUTH
// ============================================

model Admin {
  id       String    @id @default(uuid()) @db.Uuid
  email    String    @unique
  password String
  name     String
  role     AdminRole @default(ADMIN)
  isActive Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  verifiedTransactions Transactions[] @relation("TransactionVerifier")
  auditLogs           AuditLog[]      @relation("AdminAuditLogs")

  @@index([email])
  @@map("admins")
}

model Customer {
  id       String  @id @default(uuid()) @db.Uuid
  email    String  @unique
  password String
  name     String
  phone    String?
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  addresses Address[]
  cart      Cart?
  orders    Order[]

  @@index([email])
  @@map("customers")
}

// ============================================
// EX TABLE (boilerplate reference)
// ============================================

model ExTable {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@map("ex_table")
}

// ============================================
// BANNER
// ============================================
model Banner {
  id       String  @id @default(uuid()) @db.Uuid
  title    String
  imageUrl String  @map("image_url")
  linkUrl  String? @map("link_url")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([isActive])
  @@map("banners")
}

// ============================================
// PRODUCT
// ============================================
model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  products Product[]

  @@map("categories")
}

model Product {
  id         String  @id @default(uuid()) @db.Uuid
  name       String
  basePrice  Decimal @map("base_price") @db.Decimal(10, 2)
  categoryId String  @map("category_id") @db.Uuid
  isActive   Boolean @default(true) @map("is_active")

  // Inventory
  quantity    Int @default(0)
  reservedQty Int @default(0) @map("reserved_qty")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  url       String
  order     Int     @default(0)
  isMain    Boolean @default(false) @map("is_main")

  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ============================================
// VARIANT (Color + Size)
// ============================================

model Color {
  id       String    @id @default(uuid()) @db.Uuid
  color    ColorType
  isActive Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variants ProductVariant[]

  @@index([color])
  @@map("colors")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  sku       String   @unique // "SHIRT-RED-M"
  colorId   String   @map("color_id") @db.Uuid
  size      String? // nullable
  price     Decimal? @db.Decimal(10, 2) // nullable — ถ้า null ใช้ basePrice
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      Color       @relation(fields: [colorId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, colorId, size]) // กันซ้ำ
  @@index([productId])
  @@index([colorId])
  @@index([sku])
  @@map("product_variants")
}

// ============================================
// CUSTOMER ADDRESS
// ============================================

model Address {
  id         String  @id @default(uuid()) @db.Uuid
  customerId String  @map("customer_id") @db.Uuid
  label      String? // "บ้าน", "ที่ทำงาน"

  address String @map("address")

  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shippingOrders Order[]  @relation("OrderShippingAddress")

  @@index([customerId])
  @@map("addresses")
}

// ============================================
// CART
// ============================================

model Cart {
  id         String @id @default(uuid()) @db.Uuid
  customerId String @unique @map("customer_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid()) @db.Uuid
  cartId    String @map("cart_id") @db.Uuid
  productId String @map("product_id") @db.Uuid
  quantity  Int    @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart             Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId String?         @db.Uuid

  @@index([cartId])
  @@map("cart_items")
}

// ============================================
// ORDER
// ============================================

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique @map("order_number") // "ORD-20260419-0001"
  customerId  String      @map("customer_id") @db.Uuid
  status      OrderStatus @default(PENDING)

  // ราคาแยกย่อย
  discount    Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)

  // Shipping
  shippingAddressId String @map("shipping_address_id") @db.Uuid

  // Snapshot shipping (เผื่อลูกค้าลบ address)
  shippingName ShippingType

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer    Customer      @relation(fields: [customerId], references: [id])
  address     Address       @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  items       OrderItem[]
  transaction Transactions? // 1:1 — 1 order มีได้ 1 transaction

  @@index([customerId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @map("order_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  // Snapshot (สำคัญมาก!)
  productName  String    @map("product_name") // ชื่อตอนซื้อ
  productImage String?   @map("product_image") // รูปตอนซื้อ
  variantSku   String    @map("variant_sku") // SKU ตอนซื้อ
  colorName    ColorType @map("color_name") // สีตอนซื้อ
  size         String? // size ตอนซื้อ

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2) // unitPrice * quantity

  createdAt DateTime @default(now()) @map("created_at")

  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId String?         @db.Uuid

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================
// TRANSACTIONS (เดิม + เชื่อม Order แบบ 1:1)
// ============================================

model Transactions {
  id             String   @id @default(uuid()) @db.Uuid
  transaction_id String   @map("transaction_id")
  merchant_id    String   @map("merchant_id")
  order_id       String   @map("order_id") // รหัส order จาก merchant (string เดิม)
  merchant_name  String   @map("merchant_name")
  amount         Float
  status         Status
  post_request   String   @map("post_request")
  bank_request   String   @map("bank_request")
  bank_response  String   @map("bank_response")
  bank_type      BankType

  // Phase 1 — QR slip + COD
  paymentMethod PaymentMethod @default(QR) @map("payment_method")
  slipUrl       String?       @map("slip_url") // รูปสลิปที่ลูกค้าแนบ (QR เท่านั้น)

  // เชื่อมกับ Order (1:1)
  orderRef String @unique @map("order_ref") @db.Uuid
  order    Order  @relation(fields: [orderRef], references: [id])

  // Audit — ใครเป็นคน verify (optional สำหรับ manual verify)
  verifiedBy String?   @map("verified_by") @db.Uuid
  verifiedAt DateTime? @map("verified_at")
  verifier   Admin?    @relation("TransactionVerifier", fields: [verifiedBy], references: [id])

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([transaction_id])
  @@index([orderRef])
  @@index([status])
  @@map("transactions")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  action    String   // CREATE, UPDATE, DELETE
  tableName String   @map("table_name")
  recordId  String   @map("record_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  note      String?

  createdAt DateTime @default(now()) @map("created_at")

  admin Admin @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([tableName])
  @@index([createdAt])
  @@map("audit_logs")
}
